# WesternPumps frontend production environment
# Copy to frontend/.env and set correct values for your deployment.
#
# If deploying on Vercel using the repo `vercel.json` rewrites, you can omit `VITE_API_BASE_URL`
# and the frontend will call same-origin `/api/*` + `/auth/*` which Vercel rewrites to the backend.
# If you are NOT using those rewrites, set `VITE_API_BASE_URL` to your backend origin
# (e.g. `https://westernpumps-vk0u.onrender.com`).

# VITE_API_BASE_URL=
VITE_DISABLE_AUTH=false
VITE_ENABLE_AUTH_BOOTSTRAP=false
VITE_ASSISTANT_REMOTE=true
