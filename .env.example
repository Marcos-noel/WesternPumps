# MySQL (Docker)
MYSQL_DATABASE=westernpumps
MYSQL_USER=westernpumps
MYSQL_PASSWORD=westernpumps
MYSQL_ROOT_PASSWORD=root

# Backend
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
AUTO_CREATE_TABLES=true
DISABLE_AUTH=false
ENABLE_AUTH_BOOTSTRAP=false
APPROVAL_THRESHOLD_MANAGER=5000
APPROVAL_THRESHOLD_ADMIN=20000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SECURITY_HEADERS_ENABLED=true
BACKUP_ENCRYPTION_PASSPHRASE=
DEVELOPER_EMAIL=
DEVELOPER_PURGE_TOKEN=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_DISABLE_AUTH=false
VITE_ENABLE_AUTH_BOOTSTRAP=false
