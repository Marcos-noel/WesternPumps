# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://westernpumps:westernpumps@localhost:5432/westernpumps
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://western-pumps-np2i.vercel.app
AUTO_CREATE_TABLES=true
DISABLE_AUTH=false
ENABLE_AUTH_BOOTSTRAP=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=
DEVELOPER_EMAIL=
DEVELOPER_PURGE_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# WhatsApp Configuration (via Twilio)
WHATSAPP_ENABLED=false
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob: https: http:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http: https: ws: wss:
PERMISSIONS_POLICY=geolocation=(self), camera=(self), microphone=()
ENFORCE_HTTPS=false
REQUEST_ID_HEADER=X-Request-ID
MULTI_TENANT_ENABLED=false
DEFAULT_TENANT_ID=1
COMPLIANCE_MODE=standard
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_CLAIM_EMAIL=email
OIDC_CLAIM_NAME=name
OIDC_CLAIM_ROLES=roles
OIDC_AUTO_PROVISION_USERS=false
OIDC_ROLE_MAPPING_JSON={}
OUTBOX_WORKER_POLL_INTERVAL_SECONDS=3
OUTBOX_WORKER_BATCH_SIZE=30
INTEGRATION_ERP_ENABLED=false
INTEGRATION_ERP_API_BASE=
INTEGRATION_ERP_WEBHOOK=
INTEGRATION_ERP_WEBHOOK_SECRET=
INTEGRATION_ACCOUNTING_ENABLED=false
INTEGRATION_ACCOUNTING_API_BASE=
INTEGRATION_ACCOUNTING_WEBHOOK=
INTEGRATION_ACCOUNTING_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
