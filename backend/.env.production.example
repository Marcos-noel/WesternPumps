# WesternPumps backend production environment
# Copy to backend/.env and replace all placeholder values.

DATABASE_URL=postgresql://westernpumps_user:CHANGE_ME_DB_PASSWORD@db.internal:5432/westernpumps
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_64_PLUS_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Production safety
DISABLE_AUTH=false
ENABLE_AUTH_BOOTSTRAP=false
AUTO_CREATE_TABLES=false
ASSISTANT_TOOLS_ENABLED=false

# Frontend origin(s) allowed to call backend
CORS_ORIGINS=https://ops.westernpumps.company
FRONTEND_BASE_URL=https://ops.westernpumps.company

# Optional admin seed (first boot only, then remove)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=

# Optional developer-only destructive action guard
DEVELOPER_EMAIL=
DEVELOPER_PURGE_TOKEN=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional SMS
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Security headers
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https: wss:
PERMISSIONS_POLICY=geolocation=(self), camera=(self), microphone=()
ENFORCE_HTTPS=true
REQUEST_ID_HEADER=X-Request-ID
MULTI_TENANT_ENABLED=false
DEFAULT_TENANT_ID=1
COMPLIANCE_MODE=strict
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_CLAIM_EMAIL=email
OIDC_CLAIM_NAME=name
OIDC_CLAIM_ROLES=roles
OIDC_AUTO_PROVISION_USERS=false
OIDC_ROLE_MAPPING_JSON={}
OUTBOX_WORKER_POLL_INTERVAL_SECONDS=3
OUTBOX_WORKER_BATCH_SIZE=30
INTEGRATION_ERP_ENABLED=false
INTEGRATION_ERP_API_BASE=
INTEGRATION_ERP_WEBHOOK=
INTEGRATION_ERP_WEBHOOK_SECRET=
INTEGRATION_ACCOUNTING_ENABLED=false
INTEGRATION_ACCOUNTING_API_BASE=
INTEGRATION_ACCOUNTING_WEBHOOK=
INTEGRATION_ACCOUNTING_WEBHOOK_SECRET=

# LLM assistant (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
